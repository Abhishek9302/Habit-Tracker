{
  "appType": "fullstack",
  "monorepoStructure": {
    "frontend": "apps/frontend",
    "backend": "apps/backend",
    "database": "database"
  },
  "frontend": {
    "dir": "apps/frontend",
    "apiBaseEnvVar": "NEXT_PUBLIC_API_URL",
    "requiredFiles": [
      "apps/frontend/package.json",
      "apps/frontend/next.config.js",
      "apps/frontend/tailwind.config.ts",
      "apps/frontend/tsconfig.json",
      "apps/frontend/railway.toml",
      "apps/frontend/src/app/layout.tsx",
      "apps/frontend/src/app/page.tsx",
      "apps/frontend/src/app/login/page.tsx",
      "apps/frontend/src/app/register/page.tsx",
      "apps/frontend/src/app/dashboard/page.tsx",
      "apps/frontend/src/app/habits/page.tsx",
      "apps/frontend/src/app/history/page.tsx",
      "apps/frontend/src/components/AuthProvider.tsx",
      "apps/frontend/src/components/HabitCalendar.tsx",
      "apps/frontend/src/components/HabitList.tsx",
      "apps/frontend/src/components/CheckInButton.tsx",
      "apps/frontend/src/lib/api.ts",
      "apps/frontend/src/lib/auth.ts",
      "apps/frontend/src/types/index.ts"
    ]
  },
  "backend": {
    "dir": "apps/backend",
    "portEnvVar": "PORT",
    "databaseUrlEnvVar": "DATABASE_URL",
    "requiredFiles": [
      "apps/backend/package.json",
      "apps/backend/tsconfig.json",
      "apps/backend/railway.toml",
      "apps/backend/src/index.ts",
      "apps/backend/src/lib/prisma.ts",
      "apps/backend/src/lib/jwt.ts",
      "apps/backend/src/lib/password.ts",
      "apps/backend/src/middleware/auth.ts",
      "apps/backend/src/routes/auth.ts",
      "apps/backend/src/routes/habits.ts",
      "apps/backend/src/routes/checkins.ts",
      "apps/backend/src/routes/health.ts"
    ],
    "requiredRoutes": [
      "POST /api/auth/register",
      "POST /api/auth/login",
      "POST /api/auth/logout",
      "GET /api/auth/me",
      "GET /api/habits",
      "POST /api/habits",
      "GET /api/habits/:id",
      "PATCH /api/habits/:id",
      "DELETE /api/habits/:id",
      "GET /api/habits/:id/checkins",
      "POST /api/habits/:id/checkins",
      "DELETE /api/checkins/:id",
      "GET /api/checkins",
      "GET /health"
    ],
    "routeMounts": [
      {
        "mount": "/api/auth",
        "file": "apps/backend/src/routes/auth.ts",
        "handlers": [
          "POST /register",
          "POST /login",
          "POST /logout",
          "GET /me"
        ]
      },
      {
        "mount": "/api/habits",
        "file": "apps/backend/src/routes/habits.ts",
        "handlers": [
          "GET /",
          "POST /",
          "GET /:id",
          "PATCH /:id",
          "DELETE /:id",
          "GET /:id/checkins",
          "POST /:id/checkins"
        ]
      },
      {
        "mount": "/api/checkins",
        "file": "apps/backend/src/routes/checkins.ts",
        "handlers": [
          "DELETE /:id",
          "GET /"
        ]
      },
      {
        "mount": "/health",
        "file": "apps/backend/src/routes/health.ts",
        "handlers": [
          "GET /"
        ]
      }
    ]
  },
  "database": {
    "schemaFile": "database/schema.sql",
    "requiredTables": [
      "users",
      "habits",
      "checkins"
    ]
  },
  "storage": {
    "type": "database",
    "buckets": []
  }
}
